{
  "multipart": [
    {
      "when": {
        "corner": "bottom_left"
      },
      "apply": {
        "model": "searchlight:block/corner_light_base",
        "y": 0
      }
    },
    {
      "when": {
        "corner": "bottom_right"
      },
      "apply": {
        "model": "searchlight:block/corner_light_base",
        "y": 90
      }
    },
    {
      "when": {
        "corner": "top_right"
      },
      "apply": {
        "model": "searchlight:block/corner_light_base",
        "y": 180
      }
    },
    {
      "when": {
        "corner": "top_left"
      },
      "apply": {
        "model": "searchlight:block/corner_light_base",
        "y": 270
      }
    },
    {
      "when": {
        "connection": "none",
        "lit": "false"
      },
      "apply": {
        "model": "searchlight:block/corner_light_none"
      }
    },
    {
      "when": {
        "connection": "top",
        "lit": "false"
      },
      "apply": {
        "model": "searchlight:block/corner_light_top"
      }
    },
    {
      "when": {
        "connection": "bottom",
        "lit": "false"
      },
      "apply": {
        "model": "searchlight:block/corner_light_bottom"
      }
    },
    {
      "when": {
        "connection": "middle",
        "lit": "false"
      },
      "apply": {
        "model": "searchlight:block/corner_light_middle"
      }
    },
    {
      "when": {
        "connection": "none",
        "lit": "true"
      },
      "apply": {
        "model": "searchlight:block/corner_light_none_on"
      }
    },
    {
      "when": {
        "connection": "top",
        "lit": "true"
      },
      "apply": {
        "model": "searchlight:block/corner_light_top_on"
      }
    },
    {
      "when": {
        "connection": "bottom",
        "lit": "true"
      },
      "apply": {
        "model": "searchlight:block/corner_light_bottom_on"
      }
    },
    {
      "when": {
        "connection": "middle",
        "lit": "true"
      },
      "apply": {
        "model": "searchlight:block/corner_light_middle_on"
      }
    }
  ]
}